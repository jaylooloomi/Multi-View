{
   "action": {
      "default_icon": {
         "16": "icon16.png",
         "32": "icon32.png"
      },
      "default_title": "Open Side Panel"
   },
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "all_frames": true,
      "js": [ "content_script.js" ],
      "matches": [ "https://*.youtube.com/*", "https://*.nicovideo.jp/*", "https://*.vimeo.com/*", "https://*.tiktok.com/*", "https://*.twitch.tv/*", "https://*.pornhub.com/*" ],
      "run_at": "document_start"
   } ],
   "description": "Automated YouTube playlist manager with multi-screen support in the side panel.",
   "host_permissions": [ "*://www.youtube.com/*", "*://*.youtube.com/*", "*://*.googlevideo.com/*", "*://*.ytimg.com/*", "*://*.ggpht.com/*", "*://*.google.com/*", "*://*.doubleclick.net/*", "*://*.googleadservices.com/*", "*://*.nicovideo.jp/*", "*://embed.nicovideo.jp/*", "*://*.vimeo.com/*", "*://player.vimeo.com/*", "*://*.tiktok.com/*", "*://*.twitch.tv/*", "*://clips.twitch.tv/*", "*://player.twitch.tv/*", "*://*.pornhub.com/*" ],
   "key": "",
   "manifest_version": 3,
   "name": "YouTube Multi Auto Playlist",
   "permissions": [ "sidePanel", "tabs", "storage", "declarativeNetRequest", "declarativeNetRequestWithHostAccess" ],
   "side_panel": {
      "default_path": "sidepanel.html"
   },
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.1"
}
