{
   "action": {
      "default_icon": {
         "16": "icon16.png",
         "32": "icon32.png",
         "48": "icon48.png",
         "128": "icon128.png"
      },
      "default_title": "Multi-View"
   },
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "all_frames": true,
      "js": [ "content_script.js" ],
      "matches": [ "https://*.youtube.com/*", "https://*.nicovideo.jp/*", "https://*.vimeo.com/*", "https://*.tiktok.com/*", "https://*.twitch.tv/*", "https://*.pornhub.com/*", "https://*.rule34video.com/*", "https://*.ashemaletube.com/*", "https://*.xgroovy.com/*" ],
      "run_at": "document_start"
   } ],
   "description": "Multi-screen video player supporting YouTube, Pornhub, Twitch, TikTok, Vimeo, Nicovideo and more.",
   "host_permissions": [ "*://www.youtube.com/*", "*://*.youtube.com/*", "*://*.googlevideo.com/*", "*://*.ytimg.com/*", "*://*.ggpht.com/*", "*://*.google.com/*", "*://*.doubleclick.net/*", "*://*.googleadservices.com/*", "*://*.nicovideo.jp/*", "*://embed.nicovideo.jp/*", "*://*.vimeo.com/*", "*://player.vimeo.com/*", "*://*.tiktok.com/*", "*://*.twitch.tv/*", "*://clips.twitch.tv/*", "*://player.twitch.tv/*", "*://*.pornhub.com/*", "*://*.rule34video.com/*", "*://*.ashemaletube.com/*", "*://*.xgroovy.com/*" ],
   "key": "",
   "manifest_version": 3,
   "name": "Multi-View",
   "permissions": [ "sidePanel", "tabs", "storage", "declarativeNetRequest", "declarativeNetRequestWithHostAccess", "clipboardRead" ],
   "side_panel": {
      "default_path": "sidepanel.html"
   },
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "2.0"
}
